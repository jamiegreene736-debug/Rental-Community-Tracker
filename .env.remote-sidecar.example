# Remote VPS Docker sidecar (.env.remote-sidecar)
# Copy: cp .env.remote-sidecar.example .env.remote-sidecar

SIDECAR_SERVER=https://rental-community-tracker-production.up.railway.app
ADMIN_SECRET=

CHROME_PRIMARY=server
SIDECAR_BROWSER_MODE=server
SIDECAR_WORKER_ROLE=server
SIDECAR_DISABLE_LOCAL_CDP_FALLBACK=1
SERVER_CHROME_FALLBACK_ENABLED=1
SERVER_CHROME_FALLBACK_VRBO=1
MAX_LOCAL_CHROME_INSTANCES=8

CHROME_PROXY_ENABLED=1
CHROME_PROXY_PROVIDER=decodo
CHROME_PROXY_SCHEME=http
CHROME_PROXY_COUNTRY=us
DECODO_PROXY_HOST=gate.decodo.com
DECODO_PROXY_PORT=7000
DECODO_PROXY_USERNAME=
DECODO_PROXY_PASSWORD=
# Optional: DECODO_PROXY_STATE=hi DECODO_PROXY_CITY= DECODO_PROXY_SESSION_DURATION_MINUTES=20

CAPTCHA_PROVIDER=capsolver
CAPSOLVER_API_KEY=
CAPTCHA_SOLVING_ENABLED=1
