  "stayPattern": {
    "cleanFivePlusMultiplier": 1.0,
    "shortHighDemandMultiplier": 1.07,
    "difficultGapMultiplier": 1.08
  },
  "leadTime": [
    { "id": "far", "minDays": 180, "multiplier": 0.98, "label": "180+ days out" },
    { "id": "normal", "minDays": 90, "maxDays": 179, "multiplier": 1.0, "label": "90-179 days out" },
    { "id": "near", "minDays": 45, "maxDays": 89, "multiplier": 1.03, "label": "45-89 days out" },
    { "id": "urgent", "maxDays": 44, "multiplier": 1.07, "label": "Under 45 days out" }
  ]
