{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    // NOT node_modules/typescript/tsbuildinfo (the Vite template default):
    // in a git worktree with no local node_modules, tsc CREATES that dir
    // containing only this cache file, which then SHADOWS the parent-resolved
    // real typescript package and breaks every test that imports it
    // (ERR_MODULE_NOT_FOUND). .cache is not a resolvable package name.
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    }
  }
}
