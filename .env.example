# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session (required - set a random 64-char string)
SESSION_SECRET=your-long-random-secret-here

# Guesty API (required for listing builder)
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# SearchAPI.io (required for availability scanner, buy-in tracker,
# community research, and resort-fee detection during listing generation)
SEARCHAPI_API_KEY=
# Optional rotation key(s): when set, EVERY searchapi.io call automatically
# rotates to the next key on a quota / rate-limit (429) response. Add just
# SEARCHAPI_API_KEY_2 for a two-key rotation; _3.._5 and the _SECONDARY alias
# are also read if you need more.
SEARCHAPI_API_KEY_2=

# RentCast (optional — photo discovery: sale listings by city/bedrooms;
# resolves to Zillow/Realtor URLs via SearchAPI before scrape. Needs SEARCHAPI_API_KEY too.
# RentCast is deprecated for photo discovery — RealtyAPI replaces it (disabled by default).
# Set RENTCAST_DISCOVERY_ENABLED=1 only if you still call rentcast-discovery directly.
RENTCAST_API_KEY=
RENTCAST_DISCOVERY_ENABLED=0
# RENTCAST_LIMIT_PER_CITY=100
# RENTCAST_RESOLVER_MAX_LOOKUPS=40
# RENTCAST_REQUEST_TIMEOUT_MS=12000
# RENTCAST_RESOLVER_CONCURRENCY=6

# RealtyAPI (optional — Realtor.com community discovery with portal URLs;
# paginated /search/bylocation. See docs/realtyapi-photo-discovery.md.)
REALTYAPI_API_KEY=
REALTYAPI_DISCOVERY_ENABLED=1
# REALTYAPI_RESULT_COUNT=100
# REALTYAPI_MAX_PAGES_PER_LOCATION=8
# REALTYAPI_MAX_LOCATIONS=10
# REALTYAPI_REQUEST_TIMEOUT_MS=18000
# REALTYAPI_PAGE_DELAY_MS=250

# find-buy-in: PM scrapers + Google Hotels supplement (set to 0 to disable)
FIND_BUY_IN_PM_ENABLED=1

# ImgBB (optional - for photo uploads)
IMGBB_API_KEY=

# Replicate (optional - for AI features). Virtual staging reuses this provider
# by default when configured; REPLICATE_API_TOKEN is the provider's current
# name and REPLICATE_API_KEY remains supported for existing deployments.
REPLICATE_API_KEY=
REPLICATE_API_TOKEN=

# Virtual staging (server-only). The Photos tab uses image editing so room
# architecture comes from the immutable source photo instead of text alone.
REPLICATE_VIRTUAL_STAGING_MODEL=black-forest-labs/flux-2-pro
# Per-photo feedback uses a two-reference model so it can see both the immutable
# original and reviewed preview. The server downsizes only temporary provider
# upload copies to stay within FLUX.2's combined input-plus-output pixel limit.
REPLICATE_VIRTUAL_STAGING_FEEDBACK_MODEL=black-forest-labs/flux-2-pro
# Optional OpenAI fallback for virtual staging and per-photo feedback.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
# Bounded to 1-4 by the server; 2 is the default.
VIRTUAL_STAGING_CONCURRENCY=2
# Development/test-only local provider. Production rejects this setting.
VIRTUAL_STAGING_MOCK=0

# Remote sidecar: use Railway service RAILWAY_SERVICE_ROLE=sidecar-worker (see docs/remote-sidecar-setup.md).
# OTA sidecar searches run without Decodo. Leave proxy disabled unless a
# supported provider is intentionally configured for a separate environment.
CHROME_PROXY_ENABLED=0
CHROME_PROXY_PROVIDER=none
# Legacy Mac-only Chrome visibility (SIDECAR_ALLOW_LOCAL_MAC=1 install):
# Default is hidden/background. Chrome should not steal focus unless a CAPTCHA
# needs manual operator intervention.
SIDECAR_CHROME_VISIBLE=0
SIDECAR_MACOS_BACKGROUND_LAUNCH=1
SIDECAR_CHROME_HIDDEN_POSITION=-32000,-32000
SIDECAR_CHROME_VISIBLE_POSITION=120,80
# Optional visible-monitor layout. Use these when dedicating a second monitor:
# SIDECAR_CHROME_VISIBLE=1
# SIDECAR_CHROME_VISIBLE_GRID_ORIGIN=1600,60
# SIDECAR_VIEWPORT_SIZE=1600,1000
# SIDECAR_CHROME_VISIBLE_SIZE=1600,1080
# SIDECAR_CHROME_VISIBLE_GRID_COLUMNS=4
# SIDECAR_CHROME_VISIBLE_GRID_GAP_X=0
# SIDECAR_CHROME_VISIBLE_GRID_GAP_Y=0
# Or pin exact per-instance positions:
# SIDECAR_CHROME_VISIBLE_POSITIONS=1600,60;2000,60;2400,60;2800,60;1600,480;2000,480;2400,480;2800,480

# CAPTCHA handling. CapSolver credentials may be configured, but automatic
# solving is disabled by default; provider scans should surface blocked status
# and rotate/fail according to provider policy.
CAPTCHA_PROVIDER=capsolver
CAPSOLVER_API_KEY=
CAPTCHA_SOLVING_ENABLED=0
SIDECAR_VRBO_CAPTCHA_AUTOMATION=0
SIDECAR_VRBO_CAPTCHA_POLL_SECONDS=120
SIDECAR_VRBO_CAPTCHA_MAX_ATTEMPTS=1
SIDECAR_CAPTCHA_SURFACE_WINDOW=1
SIDECAR_CAPTCHA_ALLOW_FOCUS=1
SIDECAR_VRBO_MANUAL_VERIFY_TIMEOUT_MS=480000

# Sidecar throughput and recovery
MAX_LOCAL_CHROME_INSTANCES=8
SIDECAR_PM_SITE_TAB_CONCURRENCY=3
SIDECAR_PM_URL_BATCH_CONCURRENCY=8
SIDECAR_REQUEST_HARD_TIMEOUT_MS=600000
SIDECAR_REQUEST_MAX_ATTEMPTS=2
SIDECAR_REQUEST_RETRY_BASE_MS=1500

# Server-owned queue concurrency. Keep bulk listing creation conservative so
# photo scraping, copy generation, save, and pricing refresh jobs do not pile
# up and starve each other under load.
COMBO_PHOTO_FETCH_CONCURRENCY=2
BULK_COMBO_LISTING_CONCURRENCY=1
COMMUNITY_PRICING_REFRESH_CONCURRENCY=1

# Optional hybrid overflow: keep VRBO local by default because CAPTCHA/manual
# solve requires the operator Mac; enable server fallback for non-VRBO bulk work.
SERVER_CHROME_FALLBACK_ENABLED=0
SERVER_CHROME_FALLBACK_VRBO=0

# How often (in days) the background listing scanner re-checks each unit's photos
# against Airbnb/VRBO/Booking.com (the dashboard "Scanned" column). Default 7 =
# a weekly cron. Set to 1 to restore the previous daily cadence.
PHOTO_LISTING_SCAN_INTERVAL_DAYS=7
