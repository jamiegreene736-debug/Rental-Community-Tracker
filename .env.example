# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session (required - set a random 64-char string)
SESSION_SECRET=your-long-random-secret-here

# Guesty API (required for listing builder)
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# SearchAPI.io (required for availability scanner and buy-in tracker)
SEARCHAPI_API_KEY=

# ImgBB (optional - for photo uploads)
IMGBB_API_KEY=

# Replicate (optional - for AI features)
REPLICATE_API_KEY=

# VRBO sidecar Chrome visibility (local Mac operator experience)
# Default is hidden/background. Chrome should not steal focus unless a CAPTCHA
# needs manual intervention after 2Captcha fails.
SIDECAR_CHROME_VISIBLE=0
SIDECAR_MACOS_BACKGROUND_LAUNCH=1
SIDECAR_CHROME_HIDDEN_POSITION=-32000,-32000
SIDECAR_CHROME_VISIBLE_POSITION=120,80
# Optional visible-monitor layout. Use these when dedicating a second monitor:
# SIDECAR_CHROME_VISIBLE=1
# SIDECAR_CHROME_VISIBLE_GRID_ORIGIN=1600,60
# SIDECAR_CHROME_VISIBLE_GRID_COLUMNS=2
# SIDECAR_CHROME_VISIBLE_GRID_GAP_X=24
# SIDECAR_CHROME_VISIBLE_GRID_GAP_Y=36
# Or pin exact per-instance positions:
# SIDECAR_CHROME_VISIBLE_POSITIONS=1600,60;2904,60;1600,996;2904,996

# CAPTCHA handling: 2Captcha first, manual Chrome surfacing only as fallback.
SIDECAR_VRBO_2CAPTCHA=1
SIDECAR_VRBO_2CAPTCHA_POLL_SECONDS=120
SIDECAR_VRBO_2CAPTCHA_MAX_ATTEMPTS=1
SIDECAR_CAPTCHA_SURFACE_WINDOW=1
SIDECAR_CAPTCHA_ALLOW_FOCUS=1
SIDECAR_VRBO_MANUAL_VERIFY_TIMEOUT_MS=480000

# Sidecar throughput and recovery
MAX_LOCAL_CHROME_INSTANCES=8
SIDECAR_PM_SITE_TAB_CONCURRENCY=3
SIDECAR_PM_URL_BATCH_CONCURRENCY=8
SIDECAR_REQUEST_HARD_TIMEOUT_MS=600000
SIDECAR_REQUEST_MAX_ATTEMPTS=2
SIDECAR_REQUEST_RETRY_BASE_MS=1500

# Optional hybrid overflow: keep VRBO local by default because CAPTCHA/manual
# solve requires the operator Mac; enable server fallback for non-VRBO bulk work.
SERVER_CHROME_FALLBACK_ENABLED=0
SERVER_CHROME_FALLBACK_VRBO=0
