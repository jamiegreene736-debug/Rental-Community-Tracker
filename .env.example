# Database (required)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session (required - set a random 64-char string)
SESSION_SECRET=your-long-random-secret-here

# Guesty API (required for listing builder)
GUESTY_CLIENT_ID=
GUESTY_CLIENT_SECRET=

# SearchAPI.io (required for availability scanner and buy-in tracker)
SEARCHAPI_API_KEY=

# ImgBB (optional - for photo uploads)
IMGBB_API_KEY=

# Replicate (optional - for AI features)
REPLICATE_API_KEY=
